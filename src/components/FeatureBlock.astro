---
/**
 * FeatureBlock - blocos de feature (lâmpada, bike, coração)
 */
interface Props {
  icon: 'lightbulb' | 'bike' | 'heart';
  title: string;
}
const { icon, title } = Astro.props;
---

<div class="flex flex-col items-center text-center p-8 rounded-xl border border-dark-700 hover:border-accent/30 transition-colors">
  <div class="w-16 h-16 flex items-center justify-center mb-4 text-accent">
    {icon === 'lightbulb' && (
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
      </svg>
    )}
    {icon === 'bike' && (
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1h-1m-4-1a1 1 0 01-1-1V7a1 1 0 011-1h2a1 1 0 011 1v7a1 1 0 01-1 1h-1zm0-10V4a1 1 0 011-1h2a1 1 0 011 1v1" />
      </svg>
    )}
    {icon === 'heart' && (
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    )}
  </div>
  <p class="text-white">{title}</p>
</div>
