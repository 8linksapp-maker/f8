---
/**
 * FoodCard - card de restaurante/prato com imagem, tempo, rating
 */
interface Props {
  name: string;
  image: string;
  time: string;
  rating?: number;
  description?: string;
}
const { name, image, time, rating = 5, description = 'Curabitur mollis bibendum luctus..' } = Astro.props;
---

<article class="group rounded-xl overflow-hidden bg-dark-800 border border-dark-700 hover:border-accent/30 transition-all">
  <div class="relative aspect-[4/3] overflow-hidden">
    <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    <span class="absolute top-3 right-3 px-3 py-1 rounded-full bg-accent text-white text-sm font-medium">
      {time}
    </span>
  </div>
  <div class="p-4">
    <h3 class="text-lg font-semibold text-white mb-2">{name}</h3>
    <div class="flex gap-0.5 text-amber-400 mb-2">
      {Array.from({ length: 5 }).map(() => '★')}
    </div>
    <p class="text-white/60 text-sm">{description}</p>
  </div>
</article>
