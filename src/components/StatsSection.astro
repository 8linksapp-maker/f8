---
/**
 * Stats - 98%, 2k+, 35+ em cards
 */
import { siteConfig } from '../config';
---

<section class="py-16 px-6">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
    {siteConfig.stats.map((stat, i) => (
      <div
        class:list={[
          'rounded-3xl p-8 flex flex-col justify-center min-h-[180px]',
          i === 0 && 'bg-white text-dark-900',
          i === 1 && 'bg-dark-800 text-white border border-dark-700',
          i === 2 && 'bg-accent text-dark-900',
        ]}
      >
        <span class="font-display text-4xl md:text-5xl font-bold block mb-2">{stat.value}</span>
        <span class="text-sm opacity-80">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
