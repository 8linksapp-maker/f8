---
/**
 * Contact CTA - Latest creative thinking / hello@Mivon.com
 */
import { siteConfig } from '../config';
---

<section class="py-24 px-6 border-t border-dark-700">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
    <div>
      <h2 class="font-display text-4xl md:text-5xl text-white mb-4">Latest creative thinking journals.</h2>
      <a href="/blog" class="text-sm uppercase tracking-widest text-white/70 hover:text-accent transition-colors">Read Blog</a>
    </div>
    <div>
      <h2 class="font-display text-4xl md:text-5xl text-white mb-4">{siteConfig.email}</h2>
      <a href="/contact" class="text-sm uppercase tracking-widest text-white/70 hover:text-accent transition-colors">Contact Us</a>
    </div>
  </div>
</section>
