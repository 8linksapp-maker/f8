---
/**
 * Hero - seção principal estilo Mivon
 * Strategies / For branding. / Creating timeless brands / SHOW PORTFOLIO
 */
import { siteConfig } from '../config';
---

<section class="min-h-screen flex flex-col justify-center pt-24 pb-16 px-6">
  <div class="max-w-7xl mx-auto w-full">
    <p class="text-white/70 text-lg mb-6 font-body">Creating timeless brands that inspire.</p>
    <h1 class="font-display text-6xl md:text-8xl lg:text-9xl font-bold text-white leading-[0.95] tracking-tight mb-6">
      Strategi<br />es
    </h1>
    <h2 class="font-display text-4xl md:text-5xl text-white/90 mb-12">For branding.</h2>
    <a href="/works" class="inline-block text-sm uppercase tracking-widest text-white border-b-2 border-white pb-1 hover:border-accent transition-colors">
      Show Portfolio
    </a>
  </div>

  <!-- Tags -->
  <div class="max-w-7xl mx-auto w-full mt-24 flex flex-wrap gap-3">
    {['Branding', 'Web design', 'Development', 'Mobile app', 'Social media'].map((tag) => (
      <span class="px-4 py-2 rounded-full border border-white/30 text-white/80 text-sm hover:border-accent hover:text-accent transition-colors cursor-pointer">
        {tag}
      </span>
    ))}
  </div>
</section>
