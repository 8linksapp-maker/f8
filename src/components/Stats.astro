---
/**
 * Stats - estatísticas (Online Orders, Satisfied Customers, etc)
 */
const stats = [
  { icon: 'pan', value: '1052+', label: 'Online Orders' },
  { icon: 'pizza', value: '9800+', label: 'Satisfied Customers' },
  { icon: 'cup', value: '3785+', label: 'Cup of Teas' },
];
---

<section class="py-16 bg-dark-800 border-y border-dark-700">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {stats.map((stat) => (
        <div class="flex flex-col items-center text-center p-6 rounded-xl bg-dark-900/50 border border-dark-700 hover:border-accent/30 transition-colors">
          <div class="w-14 h-14 flex items-center justify-center rounded-full bg-accent/20 text-accent mb-4">
            {stat.icon === 'pan' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            )}
            {stat.icon === 'pizza' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            )}
            {stat.icon === 'cup' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            )}
          </div>
          <p class="text-2xl font-bold text-white mb-1">{stat.value}</p>
          <p class="text-white/70">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
