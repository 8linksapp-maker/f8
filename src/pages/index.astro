<!-- ═══ Spotlight onboarding ═══ -->
<div id="sp-overlay" class="hidden fixed inset-0" style="z-index:199;cursor:default">
  <div id="sp-ring" style="position:absolute;border-radius:16px;border:2px solid rgba(107,57,244,.8);pointer-events:none"></div>
  <div id="sp-lens" style="position:absolute;border-radius:12px;pointer-events:none;box-shadow:0 0 0 9999px rgba(0,0,0,.75)"></div>
  <div id="sp-tip" style="position:absolute;background:#18182b;border:1px solid rgba(107,57,244,.45);border-radius:14px;padding:16px;width:268px;box-shadow:0 12px 40px rgba(0,0,0,.6)">
    <p id="sp-msg" style="color:rgba(255,255,255,.88);font-size:13px;line-height:1.6;margin:0 0 14px"></p>
    <button id="sp-ok" type="button"
      style="display:block;width:100%;background:var(--hub-accent);color:white;border:none;padding:9px 0;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer">
      Entendi →
    </button>
  </div>
</div>

<script define:vars={{ apiUrl: 'http://127.0.0.1:3001' }}>
  // ─── State ────────────────────────────────────────────────────────────────
  let capturedPages = [];
  let pageDescriptions = {};
  let cachedSites = [];
  const STORAGE_KEY = 'criador-project-name';
  const ONBOARDED_KEY = 'f8-onboarded';
  const SP = 'f8sp_';
  let _spAC = null;

  // ─── Spotlight ────────────────────────────────────────────────────────────

  function showSpotlight(el, msg, key) {
    if (!el) return;
    if (localStorage.getItem(SP + key)) return;
    if (!document.getElementById('onboarding-overlay')?.classList.contains('hidden')) return;

    if (_spAC) { _spAC.abort(); _spAC = null; }

    const overlay = document.getElementById('sp-overlay');
    const lens    = document.getElementById('sp-lens');
    const ring    = document.getElementById('sp-ring');
    const msgEl   = document.getElementById('sp-msg');
    const tip     = document.getElementById('sp-tip');
    if (!overlay || !lens || !msgEl || !tip) return;

    const r = el.getBoundingClientRect();
    const P = 10;
    const lx = r.left - P, ly = r.top - P;
    const lw = r.width + P * 2, lh = r.height + P * 2;

    lens.style.left = lx + 'px'; lens.style.top = ly + 'px';
    lens.style.width = lw + 'px'; lens.style.height = lh + 'px';
    if (ring) {
      ring.style.left = (lx - 4) + 'px'; ring.style.top = (ly - 4) + 'px';
      ring.style.width = (lw + 8) + 'px'; ring.style.height = (lh + 8) + 'px';
    }

    msgEl.textContent = msg;

    const TW = 268, GAP = 14;
    let tx, ty;
    if (lx < 280) { // sidebar element — tooltip to the right
      tx = lx + lw + GAP;
      ty = Math.max(8, ly + lh / 2 - 65);
    } else {
      tx = Math.max(8, Math.min(lx, window.innerWidth - TW - 8));
      ty = (ly + lh + GAP + 140 < window.innerHeight) ? ly + lh + GAP : ly - GAP - 140;
    }
    tip.style.left = tx + 'px';
    tip.style.top  = ty + 'px';

    overlay.classList.remove('hidden');

    const ac = new AbortController();
    _spAC = ac;

    function dismiss() {
      localStorage.setItem(SP + key, '1');
      overlay.classList.add('hidden');
      ac.abort();
      _spAC = null;
    }

    document.getElementById('sp-ok')?.addEventListener('click', dismiss, { signal: ac.signal });
    overlay.addEventListener('click', (e) => { if (!tip.contains(e.target)) dismiss(); }, { signal: ac.signal });
  }

  // ─── Utilities ────────────────────────────────────────────────────────────

  function slugify(name) {
    return String(name || '').replace(/[^a-z0-9-]/gi, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').toLowerCase() || 'site';
  }

  function showToast(type, msg) {
    const el = document.getElementById('git-toast');
    if (!el || !msg) { if (el) el.classList.add('opacity-0'); return; }
    const bg = type === 'success' ? 'bg-emerald-600' : type === 'error' ? 'bg-red-600' : 'bg-amber-600';
    const icon = type === 'error' ? '✖' : type === 'success' ? '✓' : 'ℹ';
    el.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[400] px-4 py-3 rounded-lg text-sm font-medium shadow-xl max-w-md pointer-events-none transition-opacity duration-300 ${bg} text-white`;
    el.textContent = `${icon} ${msg}`;
    el.classList.remove('opacity-0');
    setTimeout(() => el.classList.add('opacity-0'), 4000);
  }

  // ─── Navigation ───────────────────────────────────────────────────────────

  const NAV_TITLES = {
    dashboard: 'Dashboard',
    sites: 'Meus Sites',
    create: 'Criar Site',
    settings: 'Configurações',
    feedback: 'Feedback',
  };

  function navigateTo(view) {
    document.querySelectorAll('[id^="view-"]').forEach(el => el.classList.add('hidden'));
    const target = document.getElementById(`view-${view}`);
    if (target) target.classList.remove('hidden');

    document.querySelectorAll('.nav-item[data-nav]').forEach(btn => {
      const active = btn.getAttribute('data-nav') === view;
      btn.classList.toggle('nav-active', active);
    });

    const titleEl = document.getElementById('page-title');
    if (titleEl) titleEl.textContent = NAV_TITLES[view] || '';

    if (view === 'dashboard') {
      loadSites().then(updateDashboard);
      checkTokenStatus();
      setTimeout(() => showSpotlight(document.querySelector('[data-nav="create"]'), 'Clique aqui para criar o seu primeiro site', 'nav-create'), 600);
    } else if (view === 'sites') {
      loadSites();
      setTimeout(() => showSpotlight(document.getElementById('new-project-form'), 'Digite um nome para o projeto (ex: minha-clinica) e clique em Criar', 'sites-form'), 300);
    } else if (view === 'settings') {
      refreshSettingsStatus();
      loadOrphans();
    }
  }

  document.querySelectorAll('.nav-item[data-nav]').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.getAttribute('data-nav');
      if (view) navigateTo(view);
    });
  });

  // ─── Dashboard ────────────────────────────────────────────────────────────

  function updateDashboard() {
    const total = cachedSites.length;
    const deployed = cachedSites.filter(s => s.deployUrl).length;
    const built = cachedSites.filter(s => s.hasBuild).length;

    const el = (id) => document.getElementById(id);
    if (el('stat-total')) el('stat-total').textContent = total;
    if (el('stat-deployed')) el('stat-deployed').textContent = deployed;
    if (el('stat-built')) el('stat-built').textContent = built;

    // Badge
    const badge = el('sites-count-badge');
    if (badge) { badge.textContent = String(total); badge.classList.toggle('hidden', total === 0); }

    // Recent sites
    const recentSection = el('recent-section');
    const recentList = el('recent-list');
    if (total > 0 && recentSection && recentList) {
      recentSection.classList.remove('hidden');
      recentList.innerHTML = cachedSites.slice(0, 3).map(s => {
        const slug = (s.slug || s.name || '').replace(/</g, '&lt;');
        const display = (s.displayName || s.name || slug).replace(/</g, '&lt;');
        const tag = s.deployUrl
          ? `<span class="text-xs px-2 py-1 rounded-full" style="background:rgba(16,185,129,.15);color:#10b981">Publicado</span>`
          : s.hasBuild
          ? `<span class="text-xs px-2 py-1 rounded-full" style="background:rgba(107,57,244,.15);color:var(--hub-accent)">Construído</span>`
          : `<span class="text-xs px-2 py-1 rounded-full" style="background:rgba(245,158,11,.12);color:#f59e0b">Pendente</span>`;
        return `<div class="flex items-center justify-between p-3 rounded-xl" style="background:var(--hub-bg-elevated);border:1px solid var(--hub-border)">
          <span class="text-white text-sm font-medium">${display}</span>${tag}</div>`;
      }).join('');
    } else if (recentSection) {
      recentSection.classList.add('hidden');
    }

    renderChecklist();
  }

  async function checkTokenStatus() {
    try {
      const res = await fetch(`${apiUrl}/api/credentials`);
      const data = await res.json();
      const hasToken = !!data.hasGithub;

      const banner = document.getElementById('no-token-banner');
      if (banner) banner.classList.toggle('hidden', hasToken);

      const statToken = document.getElementById('stat-token');
      if (statToken) {
        statToken.textContent = hasToken ? '✓ Configurado' : '✗ Não configurado';
        statToken.style.color = hasToken ? '#10b981' : '#f59e0b';
      }
      return hasToken;
    } catch { return false; }
  }

  async function refreshSettingsStatus() {
    try {
      const res = await fetch(`${apiUrl}/api/credentials`);
      const data = await res.json();
      const st = document.getElementById('config-github-status');
      if (st) {
        st.textContent = data.hasGithub ? '✓ Token já configurado' : '';
        st.className = 'text-xs mt-1.5 text-emerald-400';
        st.classList.toggle('hidden', !data.hasGithub);
      }
      const inp = document.getElementById('config-github-token');
      if (inp && data.hasGithub) inp.placeholder = '••••••••••••';
    } catch {}
  }

  function renderChecklist() {
    const el = document.getElementById('checklist');
    if (!el) return;
    const statToken = document.getElementById('stat-token');
    const hasToken = statToken?.textContent?.includes('✓') ?? false;
    const hasAnySite = cachedSites.length > 0;
    const hasBuilt = cachedSites.some(s => s.hasBuild);
    const hasPublished = cachedSites.some(s => s.deployUrl);

    const items = [
      { done: hasToken, label: 'Configure o token do GitHub', nav: 'settings', btn: 'Configurar' },
      { done: hasAnySite, label: 'Crie seu primeiro site', nav: 'create', btn: 'Criar site' },
      { done: hasBuilt, label: 'Construa um site (clique em Construir no card)', nav: 'sites', btn: 'Ver sites' },
      { done: hasPublished, label: 'Publique na Vercel', nav: 'sites', btn: 'Ver sites' },
    ];

    el.innerHTML = items.map(item => `
      <div class="flex items-center justify-between gap-4 px-5 py-4 checklist-row">
        <div class="flex items-center gap-3">
          <span class="w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold shrink-0"
            style="${item.done ? 'background:rgba(16,185,129,.2);color:#10b981' : 'background:rgba(255,255,255,.06);color:rgba(255,255,255,.3)'}">
            ${item.done ? '✓' : '○'}
          </span>
          <span class="text-sm" style="${item.done ? 'color:rgba(255,255,255,.35);text-decoration:line-through' : 'color:rgba(255,255,255,.8)'}">${item.label}</span>
        </div>
        ${!item.done ? `<button type="button" data-nav="${item.nav}" class="nav-item text-xs px-3 py-1.5 rounded-lg font-medium transition-colors shrink-0" style="background:rgba(107,57,244,.15);color:var(--hub-accent)">${item.btn}</button>` : ''}
      </div>
    `).join('');

    el.querySelectorAll('.nav-item[data-nav]').forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-nav');
        if (view) navigateTo(view);
      });
    });
  }

  // ─── Wizard nav helpers ───────────────────────────────────────────────────

  function showHub() { navigateTo('sites'); }

  async function showWizard(projectName) {
    const slug = slugify(projectName);
    localStorage.setItem(STORAGE_KEY, slug);
    const nameEl = document.getElementById('current-project-name');
    if (nameEl) nameEl.textContent = slug;
    const ctxBar = document.getElementById('wizard-context-bar');
    if (ctxBar) ctxBar.classList.remove('hidden');
    navigateTo('create');

    // Restore previously captured pages for this project
    capturedPages = [];
    try {
      const res = await fetch(`${apiUrl}/api/sites/${slug}/pages`);
      if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data.pages) && data.pages.length > 0) {
          capturedPages = data.pages;
          const logEl = document.getElementById('capture-log');
          if (logEl) {
            logEl.innerHTML = capturedPages.map(p =>
              `<div style="color:var(--hub-accent)">✓ ${p.slug} (capturado anteriormente)</div>`
            ).join('');
          }
          const resultEl = document.getElementById('capture-result');
          resultEl?.classList.remove('hidden');
          const countEl = document.getElementById('capture-count');
          const statusEl = document.getElementById('capture-status');
          if (countEl) countEl.textContent = `${capturedPages.length}/${capturedPages.length}`;
          if (statusEl) statusEl.textContent = 'Páginas anteriores carregadas';
        }
      }
    } catch (_) {}

    showStep(1);
  }

  // Wizard has 2 visible steps: 1=Capturar, 2=Prompts
  function showStep(n) {
    document.querySelectorAll('.wizard-step').forEach((el, i) => {
      el.classList.toggle('hidden', i + 1 !== n);
    });
    document.querySelectorAll('[data-step-ind]').forEach((el) => {
      const stepN = parseInt(el.getAttribute('data-step-ind'));
      const numEl = el.querySelector('span:first-child');
      const isActive = stepN === n;
      const isDone = stepN < n;
      el.classList.toggle('opacity-40', !isActive && !isDone);
      if (numEl) {
        numEl.style.background = isActive || isDone ? 'var(--hub-accent)' : 'rgba(255,255,255,.1)';
        numEl.style.color = isActive || isDone ? 'white' : 'rgba(255,255,255,.5)';
        numEl.textContent = isDone ? '✓' : String(stepN);
      }
    });
    if (n === 1) setTimeout(() => showSpotlight(document.getElementById('capture-btn'), 'Cole a URL do site que quer copiar como modelo no campo acima e clique em Capturar páginas', 'step1-capture'), 350);
    if (n === 2) {
      // Update the command to reference this site's prompts file
      const currentSlug = localStorage.getItem(STORAGE_KEY) || '';
      const cmd = currentSlug
        ? `rode os @f8/sites/${currentSlug}/prompts.md na sequencia`
        : 'rode os @f8/prompts-gerados.md na sequencia';
      const cmdEl = document.getElementById('cursor-command');
      if (cmdEl) cmdEl.textContent = cmd;
      window.__cursorCmd = cmd;
      setTimeout(() => showSpotlight(document.getElementById('copy-initial-btn'), 'Copie este comando e cole no Cursor para construir o site automaticamente', 'step2-copy'), 350);
    }
  }

  // ─── Render sites ─────────────────────────────────────────────────────────

  function renderSites(sites) {
    const listEl = document.getElementById('sites-list');
    const countEl = document.getElementById('sites-count');
    const search = document.getElementById('sites-search')?.value?.trim().toLowerCase() || '';
    const filtered = search
      ? sites.filter(s => (s.name || '').toLowerCase().includes(search) || (s.displayName || '').toLowerCase().includes(search))
      : sites;

    if (!listEl) return;

    if (filtered.length === 0) {
      listEl.innerHTML = sites.length === 0
        ? '<p class="text-sm py-4" style="color:rgba(255,255,255,.4)">Nenhum site criado ainda. Use o formulário acima para começar.</p>'
        : '<p class="text-sm" style="color:rgba(255,255,255,.4)">Nenhum site encontrado.</p>';
      if (countEl) countEl.classList.add('hidden');
      return;
    }

    listEl.innerHTML = filtered.map(s => {
      const slug = (s.slug || s.name || '').replace(/</g, '&lt;');
      const display = (s.displayName || s.name || slug).replace(/</g, '&lt;');
      const deployUrl = (s.deployUrl || '').replace(/"/g, '&quot;');
      const remoteUrl = (s.remoteUrl || '').replace(/"/g, '&quot;');
      const previewUrl = `${apiUrl}/preview/${slug}`;
      const hasBuild = s.hasBuild === true;

      const deployBtn = !remoteUrl
        ? `<button type="button" data-publish data-slug="${slug}"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-white font-semibold text-xs transition-colors"
            style="background:var(--hub-accent)">Publicar na Vercel</button>`
        : deployUrl
          ? `<a href="${deployUrl}" target="_blank" rel="noopener"
              class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium"
              style="border:1px solid var(--hub-border);color:rgba(255,255,255,.8)">Abrir site ↗</a>
             <button type="button" data-update data-slug="${slug}"
              class="inline-flex items-center gap-1 px-3 py-2 rounded-lg bg-white/10 hover:bg-white/20 text-white text-xs font-medium transition-colors">Atualizar</button>`
          : `<button type="button" data-connect-vercel data-slug="${slug}" data-remote="${remoteUrl}"
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-medium transition-colors"
              style="background:rgba(16,185,129,.15);color:#10b981">Conectar na Vercel ↗</button>`;

      const deployUrlInput = remoteUrl && !deployUrl
        ? `<div class="mt-3 pt-3" style="border-top:1px solid var(--hub-border)">
             <p class="text-xs mb-2" style="color:rgba(255,255,255,.4)">Após conectar na Vercel, cole a URL do seu site:</p>
             <div class="flex gap-2">
               <input type="url" data-deploy-url-input placeholder="https://meu-site.vercel.app" value="${deployUrl}"
                 class="flex-1 min-w-0 px-3 py-2 rounded-lg text-white text-xs focus:outline-none"
                 style="background:var(--hub-bg);border:1px solid var(--hub-border)" />
               <button type="button" data-save-deploy-url
                 class="px-3 py-2 rounded-lg bg-white/10 hover:bg-white/20 text-white text-xs font-medium transition-colors shrink-0">Salvar URL</button>
             </div>
           </div>`
        : '';

      return `
        <div class="p-4 rounded-xl" style="background:var(--hub-bg-elevated);border:1px solid var(--hub-border)" data-slug="${slug}">
          <div class="flex items-center justify-between gap-2 mb-3">
            <div class="min-w-0">
              <span class="font-semibold text-white">${display}</span>
              ${display !== slug ? `<span class="text-xs ml-2" style="color:rgba(255,255,255,.3)">${slug}</span>` : ''}
            </div>
            <button type="button" data-delete-site data-slug="${slug}" data-display="${display.replace(/"/g, '&quot;')}"
              class="px-2.5 py-1 rounded-lg text-xs transition-colors shrink-0"
              style="color:rgba(248,113,113,.5)">
              Excluir
            </button>
          </div>
          <div class="flex flex-wrap gap-2">
            ${hasBuild
              ? `<a href="${previewUrl}" target="_blank" rel="noopener"
                  class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium"
                  style="background:rgba(107,57,244,.15);color:var(--hub-accent)">Preview</a>`
              : `<button type="button" data-build data-slug="${slug}"
                  class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium transition-colors"
                  style="background:rgba(245,158,11,.12);color:#f59e0b">Construir</button>`
            }
            ${deployBtn}
          </div>
          ${deployUrlInput}
        </div>
      `;
    }).join('');

    if (countEl) {
      if (filtered.length !== sites.length) {
        countEl.textContent = `${filtered.length} de ${sites.length} site${sites.length !== 1 ? 's' : ''}`;
        countEl.classList.remove('hidden');
      } else {
        countEl.classList.add('hidden');
      }
    }

    // ── Bind site card events ──────────────────────────────────────────────

    listEl.querySelectorAll('[data-save-deploy-url]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('[data-slug]');
        const slug = card?.getAttribute('data-slug');
        const input = card?.querySelector('[data-deploy-url-input]');
        const url = input?.value?.trim() || '';
        if (!slug) return;
        btn.textContent = 'Salvando...'; btn.disabled = true;
        try {
          const res = await fetch(`${apiUrl}/api/sites/update-deploy-url`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug, deployUrl: url }),
          });
          const data = await res.json();
          if (res.ok && data.success) { btn.textContent = '✓ Salvo'; setTimeout(() => loadSites(), 800); }
          else throw new Error(data.error || 'Erro');
        } catch (e) {
          btn.textContent = '✖ Erro';
          setTimeout(() => { btn.textContent = 'Salvar URL'; btn.disabled = false; }, 1500);
        }
      });
    });

    listEl.querySelectorAll('[data-build]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        if (!slug) return;
        const orig = btn.textContent;
        btn.textContent = 'Construindo...'; btn.disabled = true;
        try {
          const res = await fetch(`${apiUrl}/api/sites/${slug}/build`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}',
          });
          const data = await res.json();
          if (res.ok && data.success) { showToast('success', 'Site construído'); loadSites(); }
          else {
            if (data.linkCheck?.broken?.length) {
              alert(`Links quebrados:\n\n${data.linkCheck.broken.map(b => `${b.url} (em ${b.from})`).join('\n')}`);
            }
            throw new Error(data.error || 'Erro');
          }
        } catch (e) {
          showToast('error', e instanceof Error ? e.message : 'Erro ao construir');
          btn.textContent = '✖ Erro';
          setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2500);
        }
      });
    });

    listEl.querySelectorAll('[data-publish]').forEach(btn => btn.addEventListener('click', () => handlePublish(btn)));
    listEl.querySelectorAll('[data-update]').forEach(btn => btn.addEventListener('click', () => handleUpdate(btn)));

    listEl.querySelectorAll('[data-connect-vercel]').forEach(btn => {
      btn.addEventListener('click', () => {
        const remote = btn.getAttribute('data-remote') || '';
        const repoUrl = remote.replace(/\.git$/, '');
        const url = repoUrl
          ? `https://vercel.com/new/clone?repository-url=${encodeURIComponent(repoUrl)}`
          : 'https://vercel.com/new';
        window.open(url, '_blank');
      });
    });

    listEl.querySelectorAll('[data-delete-site]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        const display = btn.getAttribute('data-display') || slug;
        if (!slug) return;
        if (!confirm(`Excluir o site "${display}"?\n\nEsta ação é irreversível.`)) return;
        btn.textContent = 'Excluindo...'; btn.disabled = true;
        try {
          const res = await fetch(`${apiUrl}/api/sites/${slug}/delete`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}',
          });
          const data = await res.json();
          if (res.ok && data.success) loadSites();
          else throw new Error(data.error || 'Erro');
        } catch (e) {
          showToast('error', e instanceof Error ? e.message : 'Erro ao excluir');
          btn.textContent = '✖ Erro';
          setTimeout(() => { btn.textContent = 'Excluir'; btn.disabled = false; }, 2000);
        }
      });
    });
  }

  // ─── Deploy handlers ──────────────────────────────────────────────────────

  async function handlePublish(btn) {
    const slug = btn.getAttribute('data-slug');
    if (!slug) return;
    const orig = btn.textContent;
    btn.textContent = 'Publicando...'; btn.disabled = true;
    try {
      const res = await fetch(`${apiUrl}/api/github/create-repo`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, doPush: true }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Erro ao criar repositório');
      loadSites();
      showPublishModal(slug, data.remoteUrl || '');
    } catch (e) {
      showToast('error', e instanceof Error ? e.message : 'Erro ao publicar');
      btn.textContent = '✖ Erro';
      setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 3000);
    }
  }

  async function handleUpdate(btn) {
    const slug = btn.getAttribute('data-slug');
    if (!slug) return;
    const orig = btn.textContent;
    btn.textContent = 'Atualizando...'; btn.disabled = true;
    try {
      const commitRes = await fetch(`${apiUrl}/api/sites/${slug}/git-commit`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: 'Atualização do site' }),
      });
      const commitData = await commitRes.json();
      if (!commitRes.ok || !commitData.success) throw new Error(commitData.error || 'Erro no commit');
      const pushRes = await fetch(`${apiUrl}/api/sites/${slug}/git-push`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}',
      });
      const pushData = await pushRes.json();
      if (!pushRes.ok || !pushData.success) throw new Error(pushData.error || 'Erro no envio');
      showToast('success', 'Site atualizado com sucesso');
      btn.textContent = '✓ Atualizado';
      setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2500);
    } catch (e) {
      showToast('error', e instanceof Error ? e.message : 'Erro ao atualizar');
      btn.textContent = '✖ Erro';
      setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 3000);
    }
  }

  function showPublishModal(slug, remoteUrl) {
    const modal = document.getElementById('publish-modal');
    const content = document.getElementById('publish-modal-content');
    if (!modal || !content) return;
    const repoUrl = remoteUrl.replace(/\.git$/, '');
    const vercelUrl = repoUrl
      ? `https://vercel.com/new/clone?repository-url=${encodeURIComponent(repoUrl)}`
      : 'https://vercel.com/new';
    content.innerHTML = `
      <div class="flex items-center gap-3 p-4 rounded-xl" style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3)">
        <span class="text-emerald-400 text-xl">✓</span>
        <div>
          <p class="text-white font-medium text-sm">Repositório criado e enviado!</p>
          ${repoUrl ? `<a href="${repoUrl}" target="_blank" class="text-emerald-400/80 text-xs underline">${repoUrl} ↗</a>` : ''}
        </div>
      </div>
      <div class="space-y-2">
        <p class="text-white/70 text-sm font-medium">Próximos passos:</p>
        <ol class="space-y-2.5 text-white/60 text-sm list-decimal list-inside">
          <li>Clique em <strong class="text-white">Abrir Vercel</strong> abaixo</li>
          <li>Siga as instruções na Vercel e clique em Deploy</li>
          <li>Aguarde o deploy concluir e copie a URL do site</li>
          <li>Feche esta janela e cole a URL no campo do card do site</li>
        </ol>
      </div>
      <a href="${vercelUrl}" target="_blank" rel="noopener"
        class="flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-white font-semibold transition-colors text-sm"
        style="background:#000;border:1px solid rgba(255,255,255,.2)">
        Abrir Vercel ↗
      </a>
    `;
    modal.classList.remove('hidden');
  }

  // ─── API ──────────────────────────────────────────────────────────────────

  async function loadSites() {
    const listEl = document.getElementById('sites-list');
    try {
      const ctrl = new AbortController();
      const t = setTimeout(() => ctrl.abort(), 4000);
      const res = await fetch(`${apiUrl}/api/sites`, { signal: ctrl.signal });
      clearTimeout(t);
      const data = await res.json();
      cachedSites = data.sites || [];
      if (listEl) renderSites(cachedSites);
    } catch {
      if (listEl) listEl.innerHTML = '<p class="text-red-400/70 text-sm">Servidor offline. Verifique se o f8 está rodando no Cursor.</p>';
    }
  }

  async function checkApiStatus() {
    const dot = document.getElementById('api-dot');
    const label = document.getElementById('api-status-label');
    try {
      const ctrl = new AbortController();
      const t = setTimeout(() => ctrl.abort(), 2500);
      const res = await fetch(`${apiUrl}/health`, { signal: ctrl.signal });
      clearTimeout(t);
      const data = await res.json();
      if (data?.ok) {
        if (dot) dot.style.background = '#10b981';
        if (label) label.textContent = 'Servidor online';
      } else throw new Error();
    } catch {
      if (dot) dot.style.background = '#ef4444';
      if (label) label.textContent = 'Servidor offline';
    }
  }

  // ─── Events: New site form ─────────────────────────────────────────────────

  document.getElementById('new-project-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('project-name');
    const name = input?.value?.trim();
    if (!name) return;
    const slug = slugify(name);
    const btn = document.getElementById('new-project-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Criando...'; }
    try {
      const res = await fetch(`${apiUrl}/api/sites/prepare`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: slug }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || `Erro ${res.status}`);
      if (input) input.value = '';
      showWizard(slug);
    } catch (err) {
      const isNet = err instanceof TypeError || (err instanceof Error && /fetch|network|refused/i.test(err.message));
      showToast('error', isNet ? 'Servidor offline. Verifique o f8 no Cursor.' : (err instanceof Error ? err.message : 'Erro ao criar site'));
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Criar'; }
    }
  });

  document.getElementById('back-to-hub')?.addEventListener('click', () => navigateTo('sites'));
  document.getElementById('go-back-hub')?.addEventListener('click', () => navigateTo('sites'));
  document.getElementById('sites-search')?.addEventListener('input', () => renderSites(cachedSites));
  document.getElementById('refresh-sites-btn')?.addEventListener('click', () => loadSites());
  document.getElementById('dash-config-btn')?.addEventListener('click', () => navigateTo('settings'));

  // ─── Events: Config form (settings view) ──────────────────────────────────

  document.getElementById('config-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const tokenEl = document.getElementById('config-github-token');
    const token = tokenEl?.value?.trim();
    if (!token) { showToast('error', 'Cole o token antes de salvar.'); return; }
    const submitBtn = e.currentTarget.querySelector('button[type="submit"]');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Salvando...'; }
    try {
      const res = await fetch(`${apiUrl}/api/credentials`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ githubToken: token }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erro');
      if (tokenEl) tokenEl.value = '';
      showToast('success', 'Token salvo com sucesso');
      checkTokenStatus();
      refreshSettingsStatus();
    } catch (err) {
      showToast('error', err instanceof Error ? err.message : 'Erro ao salvar');
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Salvar token'; }
    }
  });

  // ─── Events: Publish modal ────────────────────────────────────────────────

  document.getElementById('close-publish-modal-btn')?.addEventListener('click', () => {
    document.getElementById('publish-modal')?.classList.add('hidden');
  });
  document.getElementById('publish-modal')?.addEventListener('click', e => {
    if (e.target === document.getElementById('publish-modal'))
      document.getElementById('publish-modal')?.classList.add('hidden');
  });

  // ─── Wizard: always 100% fiel opts ───────────────────────────────────────
  const FIXED_OPTS = ['fiel-referencia', 'manter-traduzir', 'manter-cores', 'traduzir-pt'];

  // ─── Wizard Step 1: Capture ───────────────────────────────────────────────

  document.getElementById('capture-btn')?.addEventListener('click', async () => {
    const urls = (document.getElementById('urls-input')?.value || '')
      .split('\n').map(u => u.trim()).filter(u => u.startsWith('http://') || u.startsWith('https://'));
    const errEl = document.getElementById('capture-error');
    if (!urls.length) {
      if (errEl) { errEl.textContent = 'Cole pelo menos uma URL válida (começa com https://).'; errEl.classList.remove('hidden'); }
      return;
    }

    const btn = document.getElementById('capture-btn');
    const progressEl = document.getElementById('capture-progress');
    const statusEl = document.getElementById('capture-status');
    const countEl = document.getElementById('capture-count');
    const barEl = document.getElementById('capture-progress-bar');
    const logEl = document.getElementById('capture-log');
    const resultEl = document.getElementById('capture-result');

    btn.disabled = true;
    errEl?.classList.add('hidden');
    resultEl?.classList.add('hidden');
    progressEl?.classList.remove('hidden');
    logEl.innerHTML = '';
    capturedPages = [];

    const total = urls.length;
    for (let i = 0; i < urls.length; i++) {
      const url = urls[i];
      if (statusEl) statusEl.textContent = `Capturando página ${i + 1} de ${total}...`;
      if (countEl) countEl.textContent = `${i + 1}/${total}`;
      if (barEl) barEl.style.width = `${(i / total) * 100}%`;

      const logEntry = document.createElement('div');
      logEntry.style.color = 'rgba(255,255,255,.4)';
      logEntry.textContent = `⏳ ${url.slice(-65)}`;
      logEl.appendChild(logEntry);
      logEntry.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      try {
        const res = await fetch(`${apiUrl}/api/capture`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erro');
        if (data.pages?.[0]) {
          capturedPages.push(data.pages[0]);
          logEntry.style.color = 'var(--hub-accent)';
          logEntry.textContent = `✓ ${data.pages[0].slug}`;
        }
      } catch (e) {
        logEntry.style.color = '#f87171';
        logEntry.textContent = `✖ Falha: ${e instanceof Error ? e.message : 'Erro'}`;
        if (errEl) { errEl.textContent = 'Erro na captura. O f8 está rodando no Cursor?'; errEl.classList.remove('hidden'); }
        break;
      }
    }

    if (barEl) barEl.style.width = '100%';
    if (countEl) countEl.textContent = `${capturedPages.length}/${total}`;
    if (statusEl) statusEl.textContent = capturedPages.length === total ? 'Pronto!' : `Concluído com erros (${capturedPages.length}/${total})`;
    if (capturedPages.length > 0) {
      resultEl?.classList.remove('hidden');
      setTimeout(() => showSpotlight(document.getElementById('go-prompts-btn'), 'Captura concluída! Clique aqui para gerar os prompts', 'step1-done'), 400);
    }
    btn.disabled = false;
  });

  // ─── Wizard: go to prompts (step 2) ──────────────────────────────────────

  document.getElementById('go-prompts-btn')?.addEventListener('click', async () => {
    const slug = localStorage.getItem(STORAGE_KEY) || 'meu-site';
    const btn = document.getElementById('go-prompts-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Gerando...'; }

    // Ensure site is prepared
    try {
      await fetch(`${apiUrl}/api/sites/prepare`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: slug }),
      });
    } catch (_) {}

    // Build prompts with fixed opts (always 100% fiel)
    const pagePrompts = capturedPages.map(p => buildPagePrompt(p, FIXED_OPTS, '', '', slug));
    const fullBatch = buildFullBatch(pagePrompts, slug);
    window.__fullBatch = fullBatch;

    // Auto-save prompts into the site's own folder
    try {
      const saveRes = await fetch(`${apiUrl}/api/save-prompts`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: fullBatch, slug, pages: capturedPages.map(p => p.slug) }),
      });
      if (!saveRes.ok) {
        const errData = await saveRes.json().catch(() => ({}));
        showToast('error', `Erro ao salvar prompts.md: ${errData.error || saveRes.status}. Servidor f8 rodando?`);
      }
    } catch (_) {
      showToast('error', 'Não foi possível salvar prompts.md. Certifique-se que o servidor f8 está rodando (bun run dev).');
    }

    const promptsList = document.getElementById('prompts-list');
    if (promptsList) {
      promptsList.innerHTML = capturedPages.map((p, i) => `
        <div class="px-4 py-3" style="background:var(--hub-bg-elevated)">
          <p class="text-xs font-medium mb-2" style="color:rgba(255,255,255,.5)">${p.slug}</p>
          <pre class="text-xs whitespace-pre-wrap overflow-x-auto max-h-40 overflow-y-auto"
            style="color:rgba(255,255,255,.6)">${pagePrompts[i].replace(/</g, '&lt;')}</pre>
        </div>
      `).join('');
    }

    if (btn) { btn.disabled = false; btn.textContent = 'Gerar prompts →'; }
    showStep(2);
  });

  document.getElementById('copy-initial-btn')?.addEventListener('click', () => {
    const cmd = window.__cursorCmd || document.getElementById('cursor-command')?.textContent || 'rode os @f8/prompts-gerados.md na sequencia';
    navigator.clipboard.writeText(cmd).then(() => {
      const b = document.getElementById('copy-initial-btn');
      if (b) { b.textContent = '✓ Copiado!'; setTimeout(() => { b.textContent = 'Copiar'; }, 2500); }
    });
  });

  // ─── Prompt builders ──────────────────────────────────────────────────────

  function buildBasePrompt(opts, briefingText) {
    const parts = [];
    if (opts.includes('manter-traduzir')) parts.push('Manter a estrutura original da referência, apenas traduzir e adaptar ao briefing.');
    if (opts.includes('simplificar')) parts.push('Simplificar o layout (menos seções, mais enxuto).');
    if (opts.includes('manter-cores')) parts.push('Manter as cores da referência.');
    if (opts.includes('traduzir-pt')) parts.push('Todo conteúdo em português.');
    if (opts.includes('remover-elementos')) parts.push('Remover elementos desnecessários.');
    if (opts.includes('fiel-referencia')) parts.push('Manter 100% fiel à referência, apenas trocar textos.');
    if (opts.includes('recriar-inspirado')) parts.push('Recriar do zero inspirado na referência.');
    if (briefingText) parts.push(`Briefing: ${briefingText}`);
    return parts.join(' ');
  }

  function buildPagePrompt(page, opts, briefingText, pageDesc, projectSlug) {
    const hasImages = (page.files || []).some(f => f.includes('/images/'));
    const imagesNote = hasImages
      ? `\nIMAGENS: Use public/reference/${page.slug}/images/ (images.json). No Astro: src="/reference/${page.slug}/images/img-XXX.ext"`
      : '\nIMAGENS: Use placeholders (picsum.photos, Unsplash) onde necessário.';
    const base = buildBasePrompt(opts, briefingText);

    let contentBlock = '';
    const cd = page.contentData;
    if (cd) {
      const parts = [];
      if (cd.colors) parts.push(`CORES: fundo=${cd.colors.bg.join(', ')} | texto=${cd.colors.text.join(', ')} | destaque=${cd.colors.accent.join(', ')}`);
      if (cd.fonts?.length) parts.push(`FONTES: ${cd.fonts.join(', ')}`);
      if (cd.nav?.length) parts.push(`NAVEGAÇÃO: ${cd.nav.join(' | ')}`);
      if (cd.sections?.length) {
        const s = cd.sections.map(sec => {
          let d = sec.tag;
          if (sec.heading) d += ` "${sec.heading}"`;
          if (sec.layout && sec.layout !== 'block') d += ` [${sec.layout}${sec.columns ? ` ${sec.columns}col` : ''}]`;
          return d;
        }).join(' → ');
        parts.push(`ESTRUTURA: ${s}`);
      }
      if (cd.buttons?.length) parts.push(`BOTÕES/CTAs: ${cd.buttons.join(', ')}`);
      if (cd.headings?.length) parts.push(`HEADINGS: ${cd.headings.map(h => `${h.tag}: ${h.text}`).join(' | ')}`);
      if (cd.keyText?.length) parts.push(`TEXTO PRINCIPAL: ${cd.keyText.join(' ')}`);
      contentBlock = '\n\nCONTEÚDO DA REFERÊNCIA:\n' + parts.join('\n');
    }

    return `Com base em public/reference/${page.slug}/, crie a página em sites/${projectSlug}/src/pages/.\n\nINSTRUÇÕES: ${base || '(Siga o briefing.)'}\n\nESTA PÁGINA: ${pageDesc || 'Seguir a referência.'}${contentBlock}\n\nUse page.html e styles.css como base.${imagesNote}\n\nAstro + Tailwind. HTML semântico e responsivo.`;
  }

  const EXTRA_PROMPTS = {
    seo: `--- PROMPT: SEO ---
Configure o SEO do site Astro:
- Meta title e description em todas as páginas (BaseLayout ou por página)
- Open Graph e Twitter Cards para compartilhamento
- Sitemap em /sitemap-index.xml (use @astrojs/sitemap)
- robots.txt em /robots.txt
- JSON-LD: Organization, WebSite (schema.org)`,

    links: `--- PROMPT: Links internos ---
Revise e garanta a estrutura de links:
- Header e footer com nav para todas as páginas
- Breadcrumbs nas páginas internas (opcional)
- Links entre conteúdo relacionado
- CTAs e botões apontando para rotas válidas`,

    menu: `--- PROMPT: Revisão - menu/navegação ---
Revise e otimize o menu de navegação (src/config.ts nav):
- Se houver mais de 6–7 itens no menu principal, agrupe para melhor UX
- Priorize no header: Início, principais serviços, Contato/Blog
- Itens menos frequentes: mover para rodapé
- Máximo recomendado no menu principal: 5–7 itens visíveis`,

    mobile: `--- PROMPT: Ajustes para mobile ---
Revise e ajuste a experiência mobile:
- Menu hambúrguer funcional (abrir/fechar, fechar ao clicar em link)
- Áreas de toque adequadas (mínimo 44x44px para botões e links)
- Viewport responsivo, sem overflow horizontal
- Imagens responsivas (max-width, object-fit)
- Espaçamento adequado em telas pequenas`,

    imagens: `--- PROMPT: Revisão - imagens quebradas ---
Revise todas as imagens do site:
- Liste cada src de img e verifique se o arquivo existe em public/
- Corrija ou substitua imagens que retornam 404
- Use placeholders (picsum.photos, Unsplash) para imagens faltantes`,

    revisao: `--- PROMPT: Revisão - links quebrados ---
Revise todos os links do site:
- Liste cada href e confira se a rota existe
- Corrija ou remova links quebrados
- Garanta que formulários e CTAs levam a rotas válidas`,

    validacao: (s) => `--- PROMPT: Validação final ---
Execute \`cd sites/${s || 'meu-site'} && bun run build\` e corrija erros.
Confira: páginas responsivas, navegação funcionando, sem links quebrados.
Site pronto e funcional.`
  };

  function buildFullBatch(pagePrompts, projectSlug) {
    const slug = projectSlug || 'meu-site';
    const intro = `# Bateria de Prompts – 8links
Execute em ordem no Cursor. Aguarde cada etapa antes da próxima.

⚠️ ISOLAMENTO OBRIGATÓRIO:
- DIRETÓRIO DO PROJETO: sites/${slug}/
- Crie e edite APENAS arquivos dentro de sites/${slug}/
- NUNCA modifique: f8/src/ (hub), f8/src/styles/hub.css, f8/src/layouts/WizardLayout.astro
- Cada site é isolado. Blog, conteúdo e assets ficam em sites/${slug}/ apenas.

`;
    const camada1 = pagePrompts.map((p, i) => `--- PROMPT ${i + 1}/${pagePrompts.length}: Construção página ${i + 1} ---\n${p}`).join('\n\n');
    const validacao = typeof EXTRA_PROMPTS.validacao === 'function' ? EXTRA_PROMPTS.validacao(slug) : EXTRA_PROMPTS.validacao;
    return intro + camada1 + '\n\n' + EXTRA_PROMPTS.seo + '\n\n' + EXTRA_PROMPTS.links + '\n\n' + EXTRA_PROMPTS.menu + '\n\n' + EXTRA_PROMPTS.mobile + '\n\n' + EXTRA_PROMPTS.imagens + '\n\n' + EXTRA_PROMPTS.revisao + '\n\n' + validacao;
  }

  // ─── Onboarding ───────────────────────────────────────────────────────────

  function showOnboarding() {
    document.getElementById('onboarding-overlay')?.classList.remove('hidden');
  }

  function hideOnboarding() {
    document.getElementById('onboarding-overlay')?.classList.add('hidden');
    localStorage.setItem(ONBOARDED_KEY, '1');
  }

  function goObStep(n) {
    [1, 2, 3].forEach(i => {
      document.getElementById(`ob-step-${i}`)?.classList.toggle('hidden', i !== n);
      const dot = document.getElementById(`ob-dot-${i}`);
      if (dot) dot.style.background = i === n ? 'var(--hub-accent)' : i < n ? 'rgba(107,57,244,.4)' : 'rgba(255,255,255,.2)';
    });
  }

  document.getElementById('ob-next-1')?.addEventListener('click', () => goObStep(2));
  document.getElementById('ob-skip-2')?.addEventListener('click', () => goObStep(3));
  document.getElementById('ob-skip-3')?.addEventListener('click', () => hideOnboarding());

  document.getElementById('ob-save-token')?.addEventListener('click', async () => {
    const tokenEl = document.getElementById('ob-github-token');
    const token = tokenEl?.value?.trim();
    const errEl = document.getElementById('ob-token-error');
    if (!token) {
      if (errEl) { errEl.textContent = 'Cole o token antes de continuar.'; errEl.classList.remove('hidden'); }
      return;
    }
    const btn = document.getElementById('ob-save-token');
    if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }
    try {
      const res = await fetch(`${apiUrl}/api/credentials`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ githubToken: token }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erro');
      if (tokenEl) tokenEl.value = '';
      if (errEl) errEl.classList.add('hidden');
      goObStep(3);
    } catch (err) {
      if (errEl) { errEl.textContent = err instanceof Error ? err.message : 'Erro ao salvar.'; errEl.classList.remove('hidden'); }
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Salvar token →'; }
    }
  });

  document.getElementById('ob-create-site')?.addEventListener('click', async () => {
    const nameEl = document.getElementById('ob-project-name');
    const name = nameEl?.value?.trim();
    if (!name) return;
    const slug = slugify(name);
    const btn = document.getElementById('ob-create-site');
    if (btn) { btn.disabled = true; btn.textContent = 'Criando...'; }
    try {
      const res = await fetch(`${apiUrl}/api/sites/prepare`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: slug }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Erro');
      hideOnboarding();
      showWizard(slug);
    } catch (err) {
      showToast('error', err instanceof Error ? err.message : 'Erro ao criar site');
      if (btn) { btn.disabled = false; btn.textContent = 'Criar site →'; }
    }
  });

  // ─── Feedback form ────────────────────────────────────────────────────────

  document.getElementById('feedback-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('fb-submit');
    const errorEl = document.getElementById('fb-error');
    const successEl = document.getElementById('fb-success');
    const tipo = document.getElementById('fb-tipo')?.value;
    const descricao = document.getElementById('fb-descricao')?.value;
    const nome = document.getElementById('fb-nome')?.value;
    const email = document.getElementById('fb-email')?.value;

    errorEl?.classList.add('hidden');
    successEl?.classList.add('hidden');

    if (!tipo || !descricao?.trim()) {
      if (errorEl) errorEl.textContent = 'Preencha o tipo e a descrição antes de enviar.';
      errorEl?.classList.remove('hidden');
      return;
    }

    if (btn) { btn.textContent = 'Enviando...'; btn.setAttribute('disabled', ''); }

    try {
      const res = await fetch('http://localhost:3001/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tipo, descricao: descricao.trim(), nome: nome || undefined, email: email || undefined }),
      });
      const data = await res.json();
      if (data.success) {
        successEl?.classList.remove('hidden');
        document.getElementById('feedback-form')?.reset();
      } else {
        if (errorEl) errorEl.textContent = data.error || 'Erro ao enviar. Tente novamente.';
        errorEl?.classList.remove('hidden');
      }
    } catch {
      if (errorEl) errorEl.textContent = 'Não foi possível conectar. Verifique se o f8 está rodando.';
      errorEl?.classList.remove('hidden');
    } finally {
      if (btn) { btn.textContent = 'Enviar feedback'; btn.removeAttribute('disabled'); }
    }
  });

  // ─── Update system ────────────────────────────────────────────────────────

  let _updateData = null;

  async function checkForUpdates() {
    try {
      const res = await fetch(`${apiUrl}/api/update/check`);
      if (!res.ok) return;
      const data = await res.json();
      _updateData = data;
      const badge = document.getElementById('update-badge-btn');
      if (badge) badge.classList.toggle('hidden', !data.available);
      const alert = document.getElementById('update-alert-nav');
      if (alert) alert.classList.toggle('hidden', !data.available);
    } catch (_) {}
  }

  document.getElementById('update-badge-btn')?.addEventListener('click', () => openUpdateModal());
  document.getElementById('update-alert-nav')?.addEventListener('click', () => openUpdateModal());

  function openUpdateModal() {
    const modal = document.getElementById('update-modal');
    if (!modal) return;
    modal.classList.remove('hidden');
    const data = _updateData;
    const versionEl = document.getElementById('update-version-label');
    const changelogBox = document.getElementById('update-changelog-box');
    if (versionEl && data) {
      versionEl.textContent = data.localVersion
        ? `Versão atual: v${data.localVersion} · commit ${data.local || '?'} → ${data.remote || '?'}`
        : `${data.local || '?'} → ${data.remote || '?'}`;
    }
    if (changelogBox && data?.changelog?.length) {
      changelogBox.innerHTML = data.changelog.map(line => {
        const [hash, ...rest] = line.split(' ');
        return `<div class="text-xs py-0.5" style="color:rgba(255,255,255,.6)"><span style="color:rgba(255,255,255,.3);font-family:monospace">${hash}</span> ${rest.join(' ')}</div>`;
      }).join('');
    } else if (changelogBox) {
      changelogBox.innerHTML = '<p class="text-xs" style="color:rgba(255,255,255,.3)">Nenhuma informação de changelog disponível.</p>';
    }
    const statusEl = document.getElementById('update-apply-status');
    const applyBtn = document.getElementById('update-apply-btn');
    if (statusEl) statusEl.classList.add('hidden');
    if (applyBtn) { applyBtn.disabled = false; applyBtn.textContent = 'Aplicar atualização'; }
  }

  document.getElementById('update-modal-close')?.addEventListener('click', () => {
    document.getElementById('update-modal')?.classList.add('hidden');
  });

  document.getElementById('update-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
  });

  document.getElementById('update-apply-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('update-apply-btn');
    const statusEl = document.getElementById('update-apply-status');
    if (btn) { btn.disabled = true; btn.textContent = 'Aplicando...'; }
    if (statusEl) { statusEl.textContent = 'Baixando e aplicando... aguarde.'; statusEl.classList.remove('hidden'); }
    try {
      const res = await fetch(`${apiUrl}/api/update/apply`, { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        if (statusEl) statusEl.textContent = '✓ Atualização aplicada! Reinicie o servidor (feche e abra o terminal) para usar a nova versão.';
        if (btn) btn.textContent = '✓ Concluído';
        document.getElementById('update-badge-btn')?.classList.add('hidden');
        document.getElementById('update-alert-nav')?.classList.add('hidden');
        _updateData = null;
      } else {
        if (statusEl) statusEl.textContent = `Erro: ${data.error || 'Falha ao aplicar. Tente manualmente.'}`;
        if (btn) { btn.disabled = false; btn.textContent = 'Tentar novamente'; }
      }
    } catch (e) {
      if (statusEl) statusEl.textContent = 'Servidor indisponível. Certifique-se que o f8 está rodando.';
      if (btn) { btn.disabled = false; btn.textContent = 'Tentar novamente'; }
    }
  });

  // ─── Reference cleanup ────────────────────────────────────────────────────

  async function loadOrphans() {
    const statusEl = document.getElementById('orphans-status');
    const listEl = document.getElementById('orphans-list');
    const btn = document.getElementById('cleanup-refs-btn');
    try {
      const res = await fetch(`${apiUrl}/api/references/orphans`);
      if (!res.ok) throw new Error('Erro');
      const data = await res.json();
      const count = data.orphans?.length || 0;
      if (statusEl) {
        statusEl.innerHTML = count > 0
          ? `<span class="text-xs" style="color:#f87171">${count} referência(s) não usada(s) encontrada(s)</span>`
          : `<span class="text-xs" style="color:rgba(255,255,255,.35)">✓ Tudo limpo — ${data.usedCount || 0} referência(s) em uso</span>`;
      }
      if (count > 0 && listEl) {
        listEl.innerHTML = data.orphans.map(s =>
          `<div class="text-xs font-mono py-0.5" style="color:rgba(255,255,255,.4)">${s}</div>`
        ).join('');
        listEl.classList.remove('hidden');
        if (btn) btn.classList.remove('hidden');
      } else {
        listEl?.classList.add('hidden');
        if (btn) btn.classList.add('hidden');
      }
    } catch (_) {
      if (statusEl) statusEl.innerHTML = '<span class="text-xs" style="color:rgba(255,255,255,.3)">Servidor indisponível</span>';
    }
  }

  document.getElementById('cleanup-refs-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('cleanup-refs-btn');
    if (!confirm('Remover todas as referências não associadas a projetos ativos?')) return;
    if (btn) { btn.disabled = true; btn.textContent = 'Removendo...'; }
    try {
      const res = await fetch(`${apiUrl}/api/references/cleanup`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      const data = await res.json();
      if (data.success) {
        showToast('success', `${data.count} referência(s) removida(s)`);
        loadOrphans();
      } else {
        showToast('error', data.error || 'Erro ao remover');
        if (btn) { btn.disabled = false; btn.textContent = 'Remover referências não usadas'; }
      }
    } catch (_) {
      showToast('error', 'Servidor indisponível');
      if (btn) { btn.disabled = false; btn.textContent = 'Remover referências não usadas'; }
    }
  });

  // ─── Init ─────────────────────────────────────────────────────────────────

  async function loadVersion() {
    try {
      const res = await fetch(`${apiUrl}/api/version`);
      if (!res.ok) return;
      const { version, hash } = await res.json();
      const el = document.getElementById('app-version-label');
      if (el && version) el.textContent = `f8 v${version}${hash ? ` (${hash})` : ''}`;
    } catch (_) {}
  }

  async function init() {
    checkApiStatus();
    setInterval(checkApiStatus, 30000);

    await loadSites();
    await checkTokenStatus();
    updateDashboard();
    loadVersion();

    // Check for updates in background (after 3s to not block startup)
    setTimeout(checkForUpdates, 3000);
    // Recheck every 30 minutes
    setInterval(checkForUpdates, 30 * 60 * 1000);

    // Show onboarding for new users
    if (!localStorage.getItem(ONBOARDED_KEY)) {
      showOnboarding();
    }

    navigateTo('dashboard');
  }

  init();
</script>

