---
import WizardLayout from '../layouts/WizardLayout.astro';
---

<WizardLayout>
<div class="flex min-h-screen" style="background: var(--hub-bg)">

  <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
  <aside class="fixed top-0 left-0 h-screen w-60 flex flex-col z-50"
    style="background: #111; border-right: 1px solid var(--hub-border)">

    <!-- Logo -->
    <div class="px-5 py-5 shrink-0" style="border-bottom: 1px solid var(--hub-border)">
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
          style="background: var(--hub-accent)">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="white"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="white"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="white"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="white"/>
          </svg>
        </div>
        <span class="font-bold text-white text-base font-display">
          f8 <span style="color: var(--hub-accent)">Studio</span>
        </span>
      </a>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <button data-nav="dashboard" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <rect x="1.5" y="1.5" width="5" height="5" rx="1" fill="currentColor" opacity=".85"/>
          <rect x="9.5" y="1.5" width="5" height="5" rx="1" fill="currentColor" opacity=".85"/>
          <rect x="1.5" y="9.5" width="5" height="5" rx="1" fill="currentColor" opacity=".85"/>
          <rect x="9.5" y="9.5" width="5" height="5" rx="1" fill="currentColor" opacity=".85"/>
        </svg>
        Dashboard
      </button>

      <button data-nav="sites" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <path d="M2 3.5A1.5 1.5 0 013.5 2H6l2 2h4.5A1.5 1.5 0 0114 5.5v6A1.5 1.5 0 0112.5 13h-9A1.5 1.5 0 012 11.5V3.5z" fill="currentColor" opacity=".85"/>
        </svg>
        Meus Sites
        <span id="sites-count-badge"
          class="ml-auto text-xs px-1.5 py-0.5 rounded-full hidden"
          style="background: rgba(107,57,244,.2); color: var(--hub-accent)"></span>
      </button>

      <button data-nav="create" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5" opacity=".85"/>
          <path d="M8 5.5v5M5.5 8h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Criar Site
      </button>

      <div class="my-2" style="border-top: 1px solid var(--hub-border)"></div>

      <a href="/guia" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <path d="M3 2h7l3 3v9a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1z" fill="currentColor" opacity=".7"/>
          <path d="M10 2v3h3" stroke="currentColor" stroke-width="1" fill="none" opacity=".4"/>
          <path d="M5 7h6M5 9.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity=".6"/>
        </svg>
        Guia de uso
      </a>

      <button data-nav="feedback" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <path d="M2 2h12a1 1 0 011 1v7a1 1 0 01-1 1H9l-3 3v-3H2a1 1 0 01-1-1V3a1 1 0 011-1z" fill="currentColor" opacity=".7"/>
        </svg>
        Feedback
      </button>

      <!-- Update alert (yellow, shown when update available) -->
      <button id="update-alert-nav" class="hidden w-full mt-1 flex items-start gap-2.5 px-3 py-2.5 rounded-lg text-left transition-opacity hover:opacity-90"
        style="background: rgba(234,179,8,.12); border: 1px solid rgba(234,179,8,.35)">
        <span class="text-base leading-none mt-0.5">⚠️</span>
        <div>
          <p class="text-xs font-semibold" style="color: #fde047">Atualização disponível</p>
          <p class="text-xs mt-0.5" style="color: rgba(253,224,71,.6)">Clique para atualizar o f8</p>
        </div>
      </button>
    </nav>

    <!-- Bottom -->
    <div class="px-3 py-4 space-y-0.5 shrink-0" style="border-top: 1px solid var(--hub-border)">
      <button data-nav="settings" class="nav-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0">
          <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5" opacity=".85"/>
          <path d="M8 1.5v1.3M8 13.2v1.3M1.5 8h1.3M13.2 8h1.3M3.4 3.4l.9.9M11.7 11.7l.9.9M3.4 12.6l.9-.9M11.7 4.3l.9-.9"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".7"/>
        </svg>
        Configurações
      </button>

      <div class="flex items-center gap-2.5 px-3 py-2 mt-1">
        <span id="api-dot" class="w-2 h-2 rounded-full shrink-0 transition-colors" style="background: #f59e0b"></span>
        <span id="api-status-label" class="text-xs truncate" style="color: rgba(255,255,255,.35)">Verificando...</span>
      </div>

      <!-- Version label -->
      <div class="px-3 pb-1">
        <span id="app-version-label" class="text-xs font-mono" style="color: rgba(255,255,255,.18)">f8 v—</span>
      </div>

      <!-- Update badge -->
      <button id="update-badge-btn" class="hidden w-full flex items-center gap-2.5 px-3 py-2 rounded-lg transition-colors text-left"
        style="background: rgba(107,57,244,.15); border: 1px solid rgba(107,57,244,.35)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="shrink-0" style="color: var(--hub-accent)">
          <path d="M8 1v6l3-3M8 7l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2.5 10A5.5 5.5 0 108 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        </svg>
        <span class="text-xs font-medium" style="color: var(--hub-accent)">Atualização disponível</span>
      </button>
    </div>
  </aside>

  <!-- Update Modal -->
  <div id="update-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
    style="background: rgba(0,0,0,.7)">
    <div class="w-full max-w-md rounded-2xl p-6 space-y-4"
      style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-base font-bold text-white">Atualização disponível</h3>
          <p class="text-xs mt-0.5" style="color: rgba(255,255,255,.4)" id="update-version-label"></p>
        </div>
        <button id="update-modal-close" class="text-lg leading-none transition-opacity hover:opacity-60" style="color: rgba(255,255,255,.4)">✕</button>
      </div>

      <div id="update-changelog-box" class="rounded-lg p-3 max-h-48 overflow-y-auto space-y-1"
        style="background: rgba(0,0,0,.3); border: 1px solid var(--hub-border)">
        <p class="text-xs" style="color: rgba(255,255,255,.3)">Carregando...</p>
      </div>

      <div id="update-apply-area" class="space-y-3">
        <p class="text-xs" style="color: rgba(255,255,255,.45)">
          A atualização será aplicada automaticamente. Seus sites e dados não serão afetados.
        </p>
        <button id="update-apply-btn"
          class="w-full py-2.5 rounded-xl text-white text-sm font-semibold transition-colors"
          style="background: var(--hub-accent)">
          Aplicar atualização
        </button>
        <p id="update-apply-status" class="text-xs text-center hidden" style="color: rgba(255,255,255,.5)"></p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════ MAIN ═══════════════════════════ -->
  <div class="ml-60 flex-1 flex flex-col min-h-screen">

    <!-- Top bar -->
    <header class="h-14 flex items-center justify-between px-6 shrink-0"
      style="border-bottom: 1px solid var(--hub-border); background: var(--hub-bg)">
      <h1 id="page-title" class="text-base font-semibold text-white">Dashboard</h1>
    </header>

    <!-- Content -->
    <main class="flex-1 p-6">
      <div class="max-w-3xl">

        <!-- ─────────────── VIEW: Dashboard ─────────────── -->
        <div id="view-dashboard">

          <!-- Guia card (mostrado sempre) -->
          <div class="mb-6 p-4 rounded-xl flex items-center justify-between gap-4"
            style="background: rgba(107,57,244,.08); border: 1px solid rgba(107,57,244,.2)">
            <div class="flex items-center gap-3">
              <span class="text-xl shrink-0">📖</span>
              <div>
                <p class="text-sm font-medium text-white">Primeira vez aqui?</p>
                <p class="text-xs mt-0.5" style="color: rgba(255,255,255,.45)">
                  Veja o guia completo: como criar conta no GitHub, Vercel, instalar o Cursor e configurar tudo.
                </p>
              </div>
            </div>
            <a href="/guia"
              class="px-4 py-2 rounded-lg text-sm font-semibold shrink-0 transition-colors"
              style="background: var(--hub-accent); color: white">
              Ver guia
            </a>
          </div>

          <!-- No-token banner -->
          <div id="no-token-banner" class="hidden mb-6 p-4 rounded-xl flex items-center justify-between gap-4"
            style="background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.25)">
            <div class="flex items-center gap-3">
              <span class="text-amber-400 text-lg shrink-0">⚠</span>
              <div>
                <p class="text-amber-300 text-sm font-medium">Configure o token do GitHub para publicar sites</p>
                <p class="text-xs mt-0.5" style="color: rgba(252,211,77,.5)">Sem ele, os sites não podem ser enviados ao ar.</p>
              </div>
            </div>
            <button type="button" id="dash-config-btn"
              class="px-4 py-2 rounded-lg text-sm font-semibold shrink-0 transition-colors"
              style="background: rgb(245,158,11); color: black">
              Configurar agora
            </button>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            <div class="rounded-xl p-4" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
              <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: rgba(255,255,255,.4)">Sites</p>
              <p id="stat-total" class="text-2xl font-bold text-white">—</p>
            </div>
            <div class="rounded-xl p-4" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
              <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: rgba(255,255,255,.4)">Publicados</p>
              <p id="stat-deployed" class="text-2xl font-bold text-white">—</p>
            </div>
            <div class="rounded-xl p-4" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
              <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: rgba(255,255,255,.4)">Construídos</p>
              <p id="stat-built" class="text-2xl font-bold text-white">—</p>
            </div>
            <div class="rounded-xl p-4" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
              <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: rgba(255,255,255,.4)">GitHub</p>
              <p id="stat-token" class="text-sm font-medium mt-1" style="color: rgba(255,255,255,.4)">—</p>
            </div>
          </div>

          <!-- Checklist -->
          <div class="mb-8">
            <h2 class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: rgba(255,255,255,.35)">
              Próximos passos
            </h2>
            <div class="rounded-xl overflow-hidden" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
              <div id="checklist"></div>
            </div>
          </div>

          <!-- Sites recentes -->
          <div id="recent-section" class="hidden">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-xs font-semibold uppercase tracking-wider" style="color: rgba(255,255,255,.35)">
                Sites recentes
              </h2>
              <button type="button" data-nav="sites"
                class="nav-item text-xs transition-colors"
                style="color: rgba(255,255,255,.4)">
                Ver todos →
              </button>
            </div>
            <div id="recent-list" class="space-y-2"></div>
          </div>
        </div>

        <!-- ─────────────── VIEW: Meus Sites ─────────────── -->
        <div id="view-sites" class="hidden">

          <!-- New site -->
          <div class="mb-8 p-5 rounded-xl" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
            <h2 class="text-base font-semibold text-white mb-1">Novo site</h2>
            <p class="text-sm mb-4" style="color: rgba(255,255,255,.4)">
              Digite um nome para o projeto e clique em Criar.
            </p>
            <form id="new-project-form" class="flex gap-3 max-w-md">
              <input
                type="text"
                id="project-name"
                placeholder="ex: clinica-medica"
                required
                class="flex-1 px-4 py-2.5 rounded-xl text-white text-sm focus:outline-none focus:ring-2"
                style="background: var(--hub-bg); border: 1px solid var(--hub-border); --tw-ring-color: var(--hub-accent)"
              />
              <button type="submit" id="new-project-btn"
                class="px-5 py-2.5 rounded-xl text-white text-sm font-semibold transition-colors shrink-0"
                style="background: var(--hub-accent)">
                Criar
              </button>
            </form>
            <p class="text-xs mt-2" style="color: rgba(255,255,255,.25)">
              Use letras minúsculas, números e hífens. Ex: meu-pet-shop
            </p>
          </div>

          <!-- List -->
          <div>
            <div class="flex items-center justify-between gap-3 mb-4">
              <h2 class="text-xs font-semibold uppercase tracking-wider" style="color: rgba(255,255,255,.35)">
                Sites criados
              </h2>
              <div class="flex items-center gap-2">
                <input type="search" id="sites-search" placeholder="Buscar..."
                  class="px-3 py-1.5 rounded-lg text-white text-sm focus:outline-none w-36"
                  style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border); color: white; placeholder-color: rgba(255,255,255,.3)" />
                <button type="button" id="refresh-sites-btn"
                  class="px-2.5 py-1.5 rounded-lg text-sm transition-colors"
                  style="color: rgba(255,255,255,.4)"
                  title="Atualizar lista">↻</button>
              </div>
            </div>
            <div id="sites-list" class="space-y-3 min-h-[80px]">
              <p class="text-sm" style="color: rgba(255,255,255,.4)">Carregando...</p>
            </div>
            <p id="sites-count" class="text-xs mt-2 hidden" style="color: rgba(255,255,255,.3)"></p>
          </div>
        </div>

        <!-- ─────────────── VIEW: Criar Site (Wizard) ─────────────── -->
        <div id="view-create" class="hidden">

          <!-- Context bar -->
          <div id="wizard-context-bar" class="hidden flex items-center justify-between mb-6 p-3 px-4 rounded-xl text-sm"
            style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
            <span style="color: rgba(255,255,255,.5)">
              Projeto: <strong id="current-project-name" class="text-white/90"></strong>
            </span>
            <button type="button" id="back-to-hub"
              class="text-xs transition-colors"
              style="color: rgba(255,255,255,.4)">
              ← Trocar projeto
            </button>
          </div>

          <!-- Step indicator -->
          <div class="flex items-center gap-2 mb-8 select-none">
            <div data-step-ind="1" class="flex items-center gap-2">
              <span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold transition-all"
                style="background: var(--hub-accent); color: white">1</span>
              <span class="text-sm font-medium text-white">Capturar</span>
            </div>
            <div class="flex-1 border-t border-dashed" style="border-color: rgba(255,255,255,.1)"></div>
            <div data-step-ind="2" class="flex items-center gap-2 opacity-40 transition-opacity">
              <span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold transition-all"
                style="background: rgba(255,255,255,.1); color: rgba(255,255,255,.6)">2</span>
              <span class="text-sm" style="color: rgba(255,255,255,.6)">Prompts</span>
            </div>
          </div>

          <!-- STEP 1: Capturar -->
          <section id="step-1" class="wizard-step">
            <h2 class="text-xl font-bold text-white mb-1">Capturar referências</h2>
            <p class="text-sm mb-6" style="color: rgba(255,255,255,.5)">
              Cole o endereço (URL) do site que você quer usar como modelo. O f8 vai tirar uma "foto" desse site
              para o Cursor recriar depois.
            </p>

            <!-- Dica visual -->
            <div class="flex items-start gap-3 p-4 rounded-xl mb-5"
              style="background: rgba(245,158,11,.06); border: 1px solid rgba(245,158,11,.2)">
              <span class="text-amber-400 text-base shrink-0 mt-0.5">💡</span>
              <div class="text-sm" style="color: rgba(255,255,255,.6)">
                <strong class="text-white">Como achar a URL?</strong> Abra o site que você gostou no navegador,
                clique na barra de endereço no topo, copie o link e cole aqui.
                Pode colocar várias páginas, uma por linha.
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-1.5" style="color: rgba(255,255,255,.7)">
                  URLs do site de referência
                </label>
                <textarea
                  id="urls-input"
                  rows="4"
                  placeholder="https://exemplo.com&#10;https://exemplo.com/sobre&#10;https://exemplo.com/contato"
                  class="w-full px-4 py-3 rounded-xl text-white text-sm font-mono resize-none focus:outline-none focus:ring-2"
                  style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border); --tw-ring-color: var(--hub-accent)"
                ></textarea>
                <p class="text-xs mt-1.5" style="color: rgba(255,255,255,.3)">
                  Uma URL por linha. Comece pela página principal (ex: https://site.com), depois as outras páginas.
                </p>
              </div>
              <button type="button" id="capture-btn"
                class="px-6 py-3 rounded-xl text-white font-semibold transition-colors disabled:opacity-50"
                style="background: var(--hub-accent)">
                Capturar páginas
              </button>
              <div id="capture-progress" class="hidden space-y-3">
                <div class="flex justify-between text-sm" style="color: rgba(255,255,255,.6)">
                  <span id="capture-status">Iniciando...</span>
                  <span id="capture-count">0/0</span>
                </div>
                <div class="h-2 rounded-full overflow-hidden" style="background: var(--hub-bg-elevated)">
                  <div id="capture-progress-bar" class="h-full transition-all duration-300"
                    style="width: 0%; background: var(--hub-accent)"></div>
                </div>
                <div id="capture-log" class="space-y-1 text-xs font-mono max-h-28 overflow-y-auto"
                  style="color: rgba(255,255,255,.5)"></div>
              </div>
              <p id="capture-error" class="text-sm text-red-400 hidden"></p>
            </div>
            <div id="capture-result" class="mt-6 hidden">
              <div class="flex items-center gap-3 p-4 rounded-xl mb-4"
                style="background: rgba(107,57,244,.1); border: 1px solid rgba(107,57,244,.3)">
                <span style="color: var(--hub-accent)" class="text-lg">✓</span>
                <span class="text-sm" style="color: rgba(255,255,255,.9)">Páginas capturadas com sucesso!</span>
              </div>
              <button type="button" id="go-prompts-btn"
                class="px-6 py-3 rounded-xl text-white font-semibold transition-colors"
                style="background: var(--hub-accent)">
                Gerar prompts →
              </button>
            </div>
          </section>

          <!-- STEP 2: Prompts -->
          <section id="step-2" class="wizard-step hidden">
            <div class="mb-6">
              <h2 class="text-xl font-bold text-white mb-1">Prompts prontos!</h2>
              <p class="text-sm" style="color: rgba(255,255,255,.5)">
                Os prompts foram salvos automaticamente. Cole o comando abaixo no Cursor para começar.
              </p>
            </div>

            <!-- Bloco hero: comando visível -->
            <div class="p-5 rounded-xl mb-6" style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-accent)">
              <p class="text-xs font-semibold mb-2" style="color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .05em">Cole este comando no Cursor</p>
              <div class="flex items-center gap-3">
                <code id="cursor-command" class="flex-1 text-sm font-mono px-3 py-2 rounded-lg" style="background: rgba(255,255,255,.06); color: rgba(255,255,255,.9)">rode os @f8/prompts-gerados.md na sequencia</code>
                <button type="button" id="copy-initial-btn"
                  class="px-4 py-2 rounded-lg text-sm font-semibold shrink-0 transition-colors"
                  style="background: var(--hub-accent); color: white">
                  Copiar
                </button>
              </div>
            </div>

            <!-- 3 passos simplificados -->
            <div class="space-y-3 mb-8">

              <div class="flex items-start gap-4 p-4 rounded-xl"
                style="background: var(--hub-bg-elevated); border: 1px solid var(--hub-border)">
                <span class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0 mt-0.5"
                  style="background: var(--hub-accent); color: white">1</span>
                <div>
                  <p class="text-white font-semibold text-sm mb-1">Copie o comando acima</p>
                  <p class="text-xs" style="color: rgba(255,255,255,.5)">Clique no botão Copiar ao lado do comando.</p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl"
