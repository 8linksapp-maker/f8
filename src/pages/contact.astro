---
/**
 * Contact - Have a project in mind? Let's discuss.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout title="Contact Us" description="Entre em contato">
  <section class="pt-32 pb-24 px-6 min-h-screen flex flex-col justify-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-5xl md:text-7xl text-white mb-6">Have a project in mind? Let's discuss.</h1>
      <h2 class="font-display text-2xl md:text-3xl text-white/80 mb-12">Let's Start your project</h2>
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-white/60 text-sm mb-2">Nome</label>
          <input type="text" id="name" name="name" class="w-full px-4 py-3 bg-dark-800 border border-dark-700 rounded-lg text-white placeholder-white/30 focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="Seu nome" />
        </div>
        <div>
          <label for="email" class="block text-white/60 text-sm mb-2">Email</label>
          <input type="email" id="email" name="email" class="w-full px-4 py-3 bg-dark-800 border border-dark-700 rounded-lg text-white placeholder-white/30 focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="seu@email.com" />
        </div>
        <div>
          <label for="message" class="block text-white/60 text-sm mb-2">Mensagem</label>
          <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 bg-dark-800 border border-dark-700 rounded-lg text-white placeholder-white/30 focus:ring-2 focus:ring-accent focus:border-transparent resize-none" placeholder="Conte sobre seu projeto..."></textarea>
        </div>
        <button type="submit" class="px-8 py-3 bg-accent text-dark-900 font-semibold rounded-lg hover:bg-accent-hover transition-colors">
          Enviar
        </button>
      </form>
      <p class="mt-12 text-white/60">
        Ou envie direto para <a href={`mailto:${siteConfig.email}`} class="text-accent hover:underline">{siteConfig.email}</a>
      </p>
    </div>
  </section>
</BaseLayout>
